---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import BottomNav from '../components/BottomNav.astro'
import PatternCard from '../components/PatternCard.astro'
import { api } from '../lib/api'
import { PATTERNS, type Pattern } from '@repo/core'
import { i18n } from '../i18n'

// El idioma se deriva del prefijo de la URL (i18n fallbackType: 'rewrite').
const { t } = i18n(Astro)

// Catálogo desde el backend (getAllPatterns). Si el backend falla, caemos a los
// PATTERNS de @repo/core (la misma fuente de verdad) para que la página no rompa.
let patterns: Pattern[]
try {
  patterns = await api.getAllPatterns()
} catch {
  patterns = PATTERNS
}
---

<Layout title={t('patrones.meta.title')} description={t('patrones.meta.description')}>
  <Header />

  <main class="max-w-container mx-auto px-lg py-xl pb-24 md:pb-xl">
    <!-- Encabezado -->
    <div class="mb-xl max-w-3xl">
      <div
        class="inline-block bg-primary-container text-on-primary-container px-3 py-1 rounded-sm mb-md font-label-caps text-label-caps"
      >
        {t('patrones.badge')}
      </div>
      <h1
        class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-md leading-tight"
      >
        {t('patrones.title')}
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant">
        {t('patrones.subtitle')}
      </p>
    </div>

    <!-- Grilla de patrones -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
      {patterns.map((pattern) => <PatternCard pattern={pattern} />)}
    </div>

    <!-- Banda decorativa -->
    <div class="mt-xl grid grid-cols-1 md:grid-cols-3 gap-md" aria-hidden="true">
      <div
        class="bg-primary-container p-md border-l-4 border-primary h-32 flex items-end"
      >
        <p class="text-on-primary-container font-label-caps text-[10px] leading-none">
          ANALYSIS_LAYER_01: COORDINATED_REPLICATION
        </p>
      </div>
      <div
        class="bg-surface-container-highest p-md h-32 flex items-center justify-center opacity-30"
      >
        <span class="material-symbols-outlined text-outline text-[64px]">fingerprint</span>
      </div>
      <div class="bg-secondary-container p-md h-32 flex flex-col justify-between">
        <div class="flex justify-between">
          <div class="w-2 h-2 bg-on-secondary-container rounded-full"></div>
          <div class="w-2 h-2 bg-on-secondary-container rounded-full"></div>
        </div>
        <p class="text-on-secondary-container font-bold font-label-caps text-[12px] uppercase">
          Data Laboratory Active
        </p>
      </div>
    </div>
  </main>

  <BottomNav active="patrones" />
</Layout>
