---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import BottomNav from "../components/BottomNav.astro";
import ClaimForm from "../components/ClaimForm.astro";
import ClaimResult from "../components/ClaimResult.astro";

export const prerender = true;
---

<Layout
    title="Verificar una noticia - VerificaVzla"
    description="Herramienta de verificación: analiza afirmaciones virales, tweets o cadenas de WhatsApp y obtén un veredicto basado en fuentes confiables."
>
    <Header />

    <main
        class="flex-grow flex flex-col items-center px-md py-xl pb-24 md:pb-xl"
    >
        <div class="w-full max-w-[720px] flex flex-col gap-xl">
            <!-- Encabezado -->
            <div class="max-w-3xl">
                <div
                    class="inline-block bg-primary-container text-on-primary-container px-3 py-1 rounded-sm mb-md font-label-caps text-label-caps"
                >
                    LABORATORIO DE VERIFICACIÓN
                </div>
                <h1
                    class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-md leading-tight"
                >
                    Verifica una afirmación
                </h1>
                <p class="font-body-lg text-body-lg text-on-surface-variant">
                    Pega el texto, tweet o cadena de WhatsApp que quieras
                    revisar. Nuestro equipo lo contrasta con fuentes oficiales y
                    devuelve un veredicto.
                </p>
            </div>

            <ClaimForm />
            <ClaimResult />
        </div>
    </main>

    <BottomNav active="Verificar" />
</Layout>
