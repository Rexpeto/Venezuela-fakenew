---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import BottomNav from '../components/BottomNav.astro'
import { i18n } from '../i18n'

// El idioma se deriva del prefijo de la URL (i18n fallbackType: 'rewrite').
const { t } = i18n(Astro)

// Cadenas que necesita el script cliente (no puede llamar a t()).
const jsStrings = {
  verifying: t('verificar.js.verifying'),
  verdict: {
    verdadero: t('verificar.js.verdict.verdadero'),
    falso: t('verificar.js.verdict.falso'),
    dudoso: t('verificar.js.verdict.dudoso'),
  },
  conf: {
    alta: t('verificar.js.conf.alta'),
    media: t('verificar.js.conf.media'),
    baja: t('verificar.js.conf.baja'),
  },
  error: t('verificar.js.error'),
}
---

<Layout title={t('verificar.meta.title')} description={t('verificar.meta.description')}>
  <script is:inline type="application/json" id="i18n-data" set:html={JSON.stringify(jsStrings)} />
  <Header />

  <main class="flex-grow flex flex-col items-center px-md py-xl pb-24 md:pb-xl">
    <div class="w-full max-w-[720px] flex flex-col gap-xl">
      <!-- Encabezado -->
      <div class="max-w-3xl">
        <div
          class="inline-block bg-primary-container text-on-primary-container px-3 py-1 rounded-sm mb-md font-label-caps text-label-caps"
        >
          {t('verificar.badge')}
        </div>
        <h1
          class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-md leading-tight"
        >
          {t('verificar.title')}
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          {t('verificar.subtitle')}
        </p>
      </div>

      <!-- Formulario de entrada -->
      <section
        class="bg-surface-container-lowest border border-outline-variant p-lg rounded-lg"
      >
        <form id="verify-form" class="flex flex-col gap-md">
          <div class="flex flex-col gap-xs">
            <label
              for="claim"
              class="font-label-caps text-label-caps text-on-surface-variant"
              >{t('verificar.form.label')}</label
            >
            <textarea
              id="claim"
              name="claim"
              rows="4"
              required
              class="w-full bg-surface border border-outline focus:border-secondary-container focus:ring-0 rounded p-sm font-body-md text-on-surface transition-all resize-none"
              placeholder={t('verificar.form.placeholder')}
            ></textarea>
          </div>

          <!-- Acordeón: contexto opcional -->
          <div class="group border-b border-outline-variant pb-base">
            <button
              type="button"
              id="context-toggle"
              aria-expanded="false"
              aria-controls="context-content"
              class="w-full flex justify-between items-center py-base text-left transition-all"
            >
              <span
                class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-xs"
              >
                <span class="material-symbols-outlined text-[18px]" aria-hidden="true"
                  >add_circle</span
                >
                {t('verificar.form.addContext')}
              </span>
              <span
                class="material-symbols-outlined text-on-surface-variant transition-transform"
                aria-hidden="true">expand_more</span
              >
            </button>
            <div class="hidden mt-sm pb-sm" id="context-content">
              <label for="source" class="sr-only">{t('verificar.form.sourceLabel')}</label>
              <input
                id="source"
                name="source"
                type="text"
                class="w-full bg-surface-container-low border border-outline-variant rounded p-sm font-body-sm"
                placeholder={t('verificar.form.sourcePlaceholder')}
              />
            </div>
          </div>

          <div class="flex justify-end">
            <button
              type="submit"
              class="bg-primary hover:bg-primary-container text-on-primary font-label-caps text-label-caps px-lg py-md rounded transition-colors active:scale-95 duration-150 flex items-center gap-sm"
            >
              {t('verificar.form.submit')}
              <span class="material-symbols-outlined text-[18px]" aria-hidden="true"
                >search</span
              >
            </button>
          </div>
        </form>
      </section>

      <!-- Estado de error (oculto por defecto) -->
      <section
        id="verify-error"
        class="hidden border border-error bg-error-container/10 rounded-lg p-lg"
        role="alert"
      >
        <p id="verify-error-msg" class="font-body-md text-body-md text-error"></p>
      </section>

      <!-- Resultado (oculto hasta verificar) -->
      <section
        id="verify-result"
        class="hidden flex-col border border-outline-variant bg-surface-container-lowest rounded-lg overflow-hidden"
      >
        <!-- Banner de veredicto -->
        <div
          id="result-banner"
          class="border-t-[6px] p-lg flex justify-between items-center"
        >
          <div class="flex items-center gap-md">
            <span
              id="result-icon"
              class="material-symbols-outlined"
              style="font-size: 32px; font-variation-settings: 'FILL' 1;"
              aria-hidden="true"></span
            >
            <h2
              id="result-verdict"
              class="font-headline-md text-headline-md tracking-widest uppercase"
            ></h2>
          </div>
          <div
            class="bg-surface-container-high px-sm py-xs rounded flex items-center gap-xs"
          >
            <span class="font-label-caps text-[10px] text-on-surface-variant"
              >{t('verificar.result.confidence')}</span
            >
            <span
              id="result-confidence"
              class="font-label-caps text-label-caps text-primary"
            ></span>
          </div>
        </div>

        <!-- Explicación -->
        <div class="p-lg border-t border-outline-variant">
          <p
            id="result-explanation"
            class="font-body-lg text-body-lg text-on-surface leading-[1.6] whitespace-pre-line"
          ></p>
        </div>

        <!-- Metadatos: patrones y fuentes -->
        <div
          class="p-lg bg-surface-container-low flex flex-col gap-lg border-t border-outline-variant"
        >
          <div id="result-patterns-wrap" class="hidden flex-col gap-sm">
            <h3
              class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider"
            >
              {t('verificar.result.patternsTitle')}
            </h3>
            <div id="result-patterns" class="flex flex-col gap-sm"></div>
          </div>

          <div class="flex flex-col gap-sm">
            <h3
              class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider"
            >
              {t('verificar.result.sourcesTitle')}
            </h3>
            <ul id="result-sources" class="flex flex-col gap-xs"></ul>
            <p
              id="result-sources-empty"
              class="hidden font-body-sm text-body-sm text-on-surface-variant"
            >
              {t('verificar.result.sourcesEmpty')}
            </p>
          </div>
        </div>
      </section>
    </div>
  </main>

  <BottomNav active="verificar" />
</Layout>

<script>
  import { api } from '../lib/api'

  // Cadenas traducidas inyectadas por el server (bloque application/json).
  const I18N = JSON.parse(
    document.getElementById('i18n-data')?.textContent || '{}',
  ) as {
    verifying: string
    verdict: Record<string, string>
    conf: Record<'alta' | 'media' | 'baja', string>
    error: string
  }

  // Acordeón de contexto opcional
  const ctxToggle = document.getElementById('context-toggle')
  const ctxContent = document.getElementById('context-content')
  ctxToggle?.addEventListener('click', () => {
    const open = ctxContent?.classList.toggle('hidden') === false
    ctxToggle.setAttribute('aria-expanded', String(open))
  })

  // Estilos por veredicto. Clases literales para que Tailwind las genere.
  const VERDICT_CONFIG = {
    verdadero: {
      banner: 'border-secondary bg-secondary-container/10',
      text: 'text-secondary',
      icon: 'check_circle',
    },
    falso: {
      banner: 'border-error bg-error-container/10',
      text: 'text-error',
      icon: 'cancel',
    },
    dudoso: {
      banner: 'border-tertiary bg-tertiary-container/10',
      text: 'text-tertiary',
      icon: 'help',
    },
  } as const

  type Verdict = keyof typeof VERDICT_CONFIG

  function confidenceLabel(c: number): string {
    const pct = Math.round(c * 100)
    const tier = c >= 0.7 ? I18N.conf.alta : c >= 0.4 ? I18N.conf.media : I18N.conf.baja
    return `${tier} · ${pct}%`
  }

  const $ = (id: string) => document.getElementById(id)

  const form = document.getElementById('verify-form') as HTMLFormElement | null
  const result = $('verify-result')
  const errorBox = $('verify-error')
  const errorMsg = $('verify-error-msg')
  const submitBtn = form?.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement | null
  const submitHtml = submitBtn?.innerHTML ?? ''

  function setLoading(loading: boolean) {
    if (!submitBtn) return
    submitBtn.disabled = loading
    submitBtn.innerHTML = loading
      ? `${I18N.verifying}<span class="material-symbols-outlined text-[18px] animate-spin" aria-hidden="true">progress_activity</span>`
      : submitHtml
  }

  function renderResult(res: {
    verdict: string
    confidence: number
    explanation: string
    patterns: string[]
    sources: string[]
  }) {
    const cfg = VERDICT_CONFIG[res.verdict as Verdict] ?? VERDICT_CONFIG.dudoso

    const banner = $('result-banner')
    if (banner) banner.className = `border-t-[6px] p-lg flex justify-between items-center ${cfg.banner}`

    const icon = $('result-icon')
    if (icon) {
      icon.className = `material-symbols-outlined ${cfg.text}`
      icon.textContent = cfg.icon
    }

    const verdict = $('result-verdict')
    if (verdict) {
      verdict.className = `font-headline-md text-headline-md tracking-widest uppercase ${cfg.text}`
      verdict.textContent = I18N.verdict[res.verdict] ?? I18N.verdict.dudoso
    }

    const conf = $('result-confidence')
    if (conf) conf.textContent = confidenceLabel(res.confidence)

    const explanation = $('result-explanation')
    if (explanation) explanation.textContent = res.explanation

    // Patrones detectados
    const patternsWrap = $('result-patterns-wrap')
    const patterns = $('result-patterns')
    if (patterns && patternsWrap) {
      patterns.innerHTML = ''
      if (res.patterns.length > 0) {
        patternsWrap.classList.remove('hidden')
        patternsWrap.classList.add('flex')
        for (const p of res.patterns) {
          const row = document.createElement('div')
          row.className =
            'bg-surface-container-lowest border border-outline-variant p-md flex items-center gap-md rounded'
          row.innerHTML = `<span class="material-symbols-outlined ${cfg.text}" aria-hidden="true">hub</span><span class="font-label-caps text-label-caps text-on-surface"></span>`
          row.querySelector('span:last-child')!.textContent = p
          patterns.appendChild(row)
        }
      } else {
        patternsWrap.classList.add('hidden')
        patternsWrap.classList.remove('flex')
      }
    }

    // Fuentes
    const sources = $('result-sources') as HTMLUListElement | null
    const sourcesEmpty = $('result-sources-empty')
    if (sources && sourcesEmpty) {
      sources.innerHTML = ''
      if (res.sources.length > 0) {
        sourcesEmpty.classList.add('hidden')
        for (const url of res.sources) {
          let host = url
          try {
            host = new URL(url).hostname.replace(/^www\./, '')
          } catch {}
          const li = document.createElement('li')
          const a = document.createElement('a')
          a.href = url
          a.target = '_blank'
          a.rel = 'noopener noreferrer'
          a.className =
            'font-body-sm text-body-sm text-secondary hover:underline break-all flex items-center gap-xs'
          a.innerHTML = `<span class="material-symbols-outlined text-[16px]" aria-hidden="true">open_in_new</span>`
          a.append(host)
          li.appendChild(a)
          sources.appendChild(li)
        }
      } else {
        sourcesEmpty.classList.remove('hidden')
      }
    }

    result?.classList.remove('hidden')
    result?.classList.add('flex')
    result?.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!form) return
    const data = new FormData(form)
    const claim = String(data.get('claim') ?? '').trim()
    const source = String(data.get('source') ?? '').trim()
    if (!claim) return

    errorBox?.classList.add('hidden')
    result?.classList.add('hidden')
    setLoading(true)

    try {
      const res = await api.verifyClaim({
        claim,
        context: source || undefined,
      })
      renderResult(res)
    } catch (err) {
      console.error('verifyClaim failed', err)
      if (errorMsg) errorMsg.textContent = I18N.error
      errorBox?.classList.remove('hidden')
      errorBox?.scrollIntoView({ behavior: 'smooth', block: 'start' })
    } finally {
      setLoading(false)
    }
  })
</script>
