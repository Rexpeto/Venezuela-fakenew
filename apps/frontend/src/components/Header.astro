---
import Icon from './Icon.astro'
import LangSwitcher from './LangSwitcher.astro'
import { i18n } from '../i18n'

interface Props {
  /** En la vista de chat el hamburguesa abre el sidebar de consultas, no el menú de navegación. */
  hasSidebar?: boolean
}

const { hasSidebar = false } = Astro.props
const { t, href } = i18n(Astro)
---

<nav
    class="sticky top-0 z-50 flex h-16 w-full items-center justify-between border-b border-outline-variant bg-surface/95 px-gutter backdrop-blur-sm"
>
    <div class="flex items-center gap-sm">
        <a href={href('/')} class="flex items-center gap-sm">
            <Icon name="shield-check" size={28} class="text-primary" />
            <span
                class="font-headline-sm text-headline-sm font-bold tracking-tight text-primary"
                >VerificaVzla</span
            >
        </a>
    </div>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-lg md:flex">
        <a
            href={href('/verificar')}
            class="font-medium text-on-surface-variant transition-colors duration-200 hover:text-secondary"
        >
            {t('nav.verificar')}
        </a>
        <a
            href={href('/asistente')}
            class="font-medium text-on-surface-variant transition-colors duration-200 hover:text-secondary"
        >
            {t('nav.asistente')}
        </a>
        <a
            href={href('/patrones')}
            class="font-medium text-on-surface-variant transition-colors duration-200 hover:text-secondary"
        >
            {t('nav.patrones')}
        </a>
    </div>

    <div class="flex items-center gap-sm">
        <div class="hidden md:flex">
            <LangSwitcher />
        </div>
        <button
            id="theme-toggle"
            type="button"
            aria-label={t('nav.toggleTheme')}
            class="flex cursor-pointer items-center justify-center rounded p-2 text-on-surface-variant transition-colors hover:bg-surface-container hover:text-primary"
        >
            <Icon name="moon" size={20} class="dark:hidden" />
            <Icon name="sun" size={20} class="hidden dark:block" />
        </button>
        <a
            href="https://github.com/Rexpeto/Venezuela-fakenew"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t('nav.viewSource')}
            title="GitHub"
            class="flex items-center justify-center rounded p-2 text-on-surface-variant transition-colors hover:bg-surface-container hover:text-primary"
        >
            <Icon name="github" size={20} />
        </a>
        {hasSidebar ? (
            <button
                id="sidebar-toggle"
                class="flex cursor-pointer p-2 text-on-surface md:hidden"
                aria-label={t('nav.openQueries')}
                aria-controls="sidebar"
                aria-expanded="false"
            >
                <Icon name="menu" size={24} />
            </button>
        ) : (
            <button
                id="menu-toggle"
                class="flex cursor-pointer p-2 text-on-surface md:hidden"
                aria-label={t('nav.openMenu')}
                data-open-label={t('nav.openMenu')}
                data-close-label={t('nav.closeMenu')}
            >
                <Icon name="menu" size={24} />
            </button>
        )}
    </div>
</nav>

<!-- Mobile menu panel (oculto en el chat, donde el hamburguesa abre el sidebar) -->
{!hasSidebar && (
<div
    id="mobile-menu"
    class="fixed inset-0 z-40 flex flex-col bg-surface pt-16 transition-all duration-300 ease-out md:hidden invisible opacity-0 -translate-y-2 pointer-events-none"
    role="dialog"
    aria-modal="true"
    aria-label={t('nav.menuDialog')}
>
    <nav class="flex flex-col gap-2 px-gutter py-lg">
        <a
            href={href('/verificar')}
            class="mobile-link rounded-md px-md py-lg text-headline-md font-bold text-on-surface transition-colors hover:bg-surface-container"
        >
            {t('nav.verificar')}
        </a>
        <a
            href={href('/asistente')}
            class="mobile-link rounded-md px-md py-lg text-headline-md font-bold text-on-surface transition-colors hover:bg-surface-container"
        >
            {t('nav.asistente')}
        </a>
        <a
            href={href('/patrones')}
            class="mobile-link rounded-md px-md py-lg text-headline-md font-bold text-on-surface transition-colors hover:bg-surface-container"
        >
            {t('nav.patrones')}
        </a>
        <div class="px-md py-lg">
            <LangSwitcher />
        </div>
    </nav>
</div>
)}

<script>
    // Toggle de tema: alterna la clase .dark en <html> y la persiste.
    const themeToggle = document.getElementById('theme-toggle')
    themeToggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark')
        localStorage.setItem('theme', isDark ? 'dark' : 'light')
    })

    const toggle = document.getElementById('menu-toggle')
    const menu = document.getElementById('mobile-menu')

    if (toggle && menu) {
        let isOpen = false
        const openLabel = toggle.dataset.openLabel ?? 'Open menu'
        const closeLabel = toggle.dataset.closeLabel ?? 'Close menu'

        toggle.addEventListener('click', () => {
            isOpen = !isOpen

            // Animate: toggle visibility, opacity, and translate
            menu.classList.toggle('invisible', !isOpen)
            menu.classList.toggle('pointer-events-none', !isOpen)
            menu.classList.toggle('opacity-0', !isOpen)
            menu.classList.toggle('-translate-y-2', !isOpen)
            menu.classList.toggle('opacity-100', isOpen)
            menu.classList.toggle('translate-y-0', isOpen)
            menu.classList.toggle('pointer-events-auto', isOpen)

            toggle.setAttribute('aria-label', isOpen ? closeLabel : openLabel)
            document.body.classList.toggle('overflow-hidden', isOpen)
        })

        // Close on link click
        menu.querySelectorAll('.mobile-link').forEach((link) => {
            link.addEventListener('click', () => {
                isOpen = false
                menu.classList.add(
                    'invisible',
                    'pointer-events-none',
                    'opacity-0',
                    '-translate-y-2',
                )
                menu.classList.remove(
                    'opacity-100',
                    'translate-y-0',
                    'pointer-events-auto',
                )
                toggle.setAttribute('aria-label', openLabel)
                document.body.classList.remove('overflow-hidden')
            })
        })

        // Close on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && isOpen) {
                isOpen = false
                menu.classList.add(
                    'invisible',
                    'pointer-events-none',
                    'opacity-0',
                    '-translate-y-2',
                )
                menu.classList.remove(
                    'opacity-100',
                    'translate-y-0',
                    'pointer-events-auto',
                )
                toggle.setAttribute('aria-label', openLabel)
                document.body.classList.remove('overflow-hidden')
            }
        })
    }
</script>
