---
interface NavItem {
  label: string
  href: string
}

interface Props {
  /** Etiqueta del item de navegación activo. */
  active?: string
}

const { active } = Astro.props

const items: NavItem[] = [
  { label: 'Fact-Checks', href: '#' },
  { label: 'Patterns', href: '/patrones' },
  { label: 'Cases', href: '#' },
  { label: 'About', href: '#' },
]
---

<header class="bg-surface sticky top-0 z-50 border-b border-outline-variant">
  <div class="flex justify-between items-center px-lg py-sm max-w-[1120px] mx-auto">
    <a href="/" class="flex items-center gap-md cursor-pointer active:opacity-80">
      <span class="material-symbols-outlined text-primary">shield</span>
      <span class="font-headline-md text-headline-md text-primary">VerificaVzla</span>
    </a>

    <nav class="hidden md:flex items-center gap-lg" aria-label="Principal">
      {
        items.map((item) =>
          item.label === active ? (
            <a
              href={item.href}
              aria-current="page"
              class="text-primary font-bold border-b-2 border-primary px-3 py-1"
            >
              {item.label}
            </a>
          ) : (
            <a
              href={item.href}
              class="text-on-surface-variant hover:bg-surface-container-low transition-colors px-3 py-1"
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <div class="flex items-center gap-md">
      <button type="button" aria-label="Buscar" class="text-primary cursor-pointer">
        <span class="material-symbols-outlined">search</span>
      </button>
      <button type="button" aria-label="Abrir menú" class="md:hidden text-primary">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
</header>
