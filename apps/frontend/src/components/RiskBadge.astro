---
import type { RiskLevel } from '../lib/patterns'

interface Props {
  level: RiskLevel
}

const { level } = Astro.props

const styles: Record<RiskLevel, { bg: string; text: string; label: string }> = {
  alta: { bg: 'bg-error', text: 'text-on-error', label: 'Alta' },
  media: { bg: 'bg-warning', text: 'text-on-warning', label: 'Media' },
  baja: { bg: 'bg-secondary', text: 'text-on-secondary', label: 'Baja' },
}

const { bg, text, label } = styles[level]
---

<span
  class:list={[
    bg,
    text,
    'px-3 py-1 text-[11px] font-bold uppercase rounded-sm whitespace-nowrap',
  ]}
>
  Riesgo: {label}
</span>
