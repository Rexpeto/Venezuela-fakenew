---
import type { RiskLevel } from '../lib/patterns'
import { i18n } from '../i18n'

interface Props {
  level: RiskLevel
}

const { level } = Astro.props
const { t } = i18n(Astro)

const bgByLevel: Record<RiskLevel, string> = {
  alta: 'bg-error',
  media: 'bg-warning',
  baja: 'bg-secondary',
}
---

<span
  class:list={[
    bgByLevel[level],
    'text-white px-3 py-1 text-[11px] font-bold uppercase rounded-sm whitespace-nowrap',
  ]}
>
  {t('riskBadge.prefix')} {t(`riskBadge.${level}`)}
</span>
