---
import type { RiskLevel } from '../lib/patterns'

interface Props {
  level: RiskLevel
}

const { level } = Astro.props

const styles: Record<RiskLevel, { bg: string; label: string }> = {
  alta: { bg: 'bg-error', label: 'Alta' },
  media: { bg: 'bg-warning', label: 'Media' },
  baja: { bg: 'bg-secondary', label: 'Baja' },
}

const { bg, label } = styles[level]
---

<span
  class:list={[
    bg,
    'text-white px-3 py-1 text-[11px] font-bold uppercase rounded-sm whitespace-nowrap',
  ]}
>
  Riesgo: {label}
</span>
