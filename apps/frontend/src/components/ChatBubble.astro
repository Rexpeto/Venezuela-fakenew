---
import type { ChatRole, ChatSource } from '../lib/chat'
import SourcesAccordion from './SourcesAccordion.astro'

interface Props {
  role: ChatRole
  time: string
  sources?: ChatSource[]
}

const { role, time, sources } = Astro.props
const isUser = role === 'user'
---

{
  isUser ? (
    <div class="flex justify-end ml-xl">
      <div class="bg-primary-container text-white px-md py-sm max-w-[85%] rounded-l-xl rounded-tr-xl shadow-sm">
        <p class="font-body-md text-body-md">
          <slot />
        </p>
        <span class="block text-right text-[10px] opacity-70 mt-1">{time}</span>
      </div>
    </div>
  ) : (
    <div class="flex justify-start mr-xl">
      <div class="flex flex-col max-w-[90%] sm:max-w-[80%]">
        <div class="bg-white border border-outline-variant p-md rounded-r-xl rounded-tl-xl shadow-sm text-on-surface">
          <p class="font-body-md text-body-md">
            <slot />
          </p>
          {sources && sources.length > 0 && <SourcesAccordion sources={sources} />}
        </div>
        <span class="block text-[10px] text-on-surface-variant mt-1 ml-1">
          IA VerificaVzla • {time}
        </span>
      </div>
    </div>
  )
}
