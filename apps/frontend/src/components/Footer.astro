---
import Icon from "./Icon.astro";
import { i18n } from "../i18n";

const year = new Date().getFullYear();
const { t, href } = i18n(Astro);
---

<footer class="w-full border-t border-white/5 bg-tertiary py-xl">
  <div
    class="mx-auto flex w-full max-w-container flex-col items-center gap-md px-gutter md:flex-row md:justify-between"
  >
    <div class="flex flex-col items-center gap-sm md:items-start">
        <span class="font-headline-sm text-headline-sm font-bold text-on-tertiary"
            >VerificaVzla</span
        >
        <p
            class="text-body-sm text-tertiary-fixed-dim/80 text-center md:text-left"
        >
            © {year} VerificaVzla. {t('footer.tagline')}
        </p>
    </div>

    <div class="flex flex-wrap justify-center gap-lg">
        <a
            href={href('/verificar')}
            class="font-label-caps text-label-caps text-tertiary-fixed-dim/80 transition-colors hover:text-on-tertiary hover:underline"
        >
            {t('nav.verificar')}
        </a>
        <a
            href={href('/asistente')}
            class="font-label-caps text-label-caps text-tertiary-fixed-dim/80 transition-colors hover:text-on-tertiary hover:underline"
        >
            {t('nav.asistente')}
        </a>
        <a
            href={href('/patrones')}
            class="font-label-caps text-label-caps text-tertiary-fixed-dim/80 transition-colors hover:text-on-tertiary hover:underline"
        >
            {t('nav.patrones')}
        </a>
    </div>

    <div class="flex gap-md text-on-tertiary">
        <Icon name="share" size={20} class="cursor-pointer" />
        <Icon name="rss" size={20} class="cursor-pointer" />
    </div>
  </div>
</footer>
