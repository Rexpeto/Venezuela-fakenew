---
import Icon, { type IconName } from "./Icon.astro";
import { i18n } from "../i18n";

export type BadgeStatus =
    | "alerta-falsa"
    | "contexto-necesario"
    | "cadena-falsa";

const { status, class: className = "" } = Astro.props as {
    status: BadgeStatus;
    class?: string;
};

const { t } = i18n(Astro);

const config: Record<BadgeStatus, { icon: IconName; color: string }> = {
    "alerta-falsa": { icon: "triangle-alert", color: "text-error" },
    "contexto-necesario": { icon: "circle-x", color: "text-secondary" },
    "cadena-falsa": { icon: "message-circle-x", color: "text-error" },
};

const { icon, color } = config[status];
const label = t(`patternBadge.${status}`);
---

<div
    class:list={[
        "flex items-center gap-xs font-label-caps text-label-caps font-bold",
        color,
        className,
    ]}
>
    <Icon name={icon} size={16} />
    {label}
</div>
