---
import Icon, { type IconName } from "./Icon.astro";

export type BadgeStatus =
    | "alerta-falsa"
    | "contexto-necesario"
    | "cadena-falsa";

const { status, class: className = "" } = Astro.props as {
    status: BadgeStatus;
    class?: string;
};

const config: Record<
    BadgeStatus,
    { label: string; icon: IconName; color: string }
> = {
    "alerta-falsa": {
        label: "ALERTA FALSA",
        icon: "triangle-alert",
        color: "text-error",
    },
    "contexto-necesario": {
        label: "CONTEXTO NECESARIO",
        icon: "circle-x",
        color: "text-secondary",
    },
    "cadena-falsa": {
        label: "CADENA FALSA",
        icon: "message-circle-x",
        color: "text-error",
    },
};

const { label, icon, color } = config[status];
---

<div
    class:list={[
        "flex items-center gap-xs font-label-caps text-label-caps font-bold",
        color,
        className,
    ]}
>
    <Icon name={icon} size={16} />
    {label}
</div>
