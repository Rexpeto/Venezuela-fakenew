---
// Wrapper único para todas las tarjetas de la app: misma superficie
// (fondo + borde + radio) en claro y oscuro. El layout/padding se pasa por
// `class`; `as` permite el tag semántico (article/section/div) e `interactive`
// agrega el hover/active del catálogo. Atributos extra (id, role…) se reenvían.
const {
    as: Tag = "div",
    interactive = false,
    class: className = "",
    ...rest
} = Astro.props as {
    as?: string;
    interactive?: boolean;
    class?: string;
    [key: string]: unknown;
};
---

<Tag
    class:list={[
        "rounded-lg border border-[#e2e8f0] bg-surface-container-lowest dark:border-outline-variant",
        interactive &&
            "transition-[transform,box-shadow] duration-200 hover:shadow-md active:scale-95",
        className,
    ]}
    {...rest}
>
    <slot />
</Tag>
