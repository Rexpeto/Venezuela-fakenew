---
import Card from "./Card.astro";
import PatternBadge from "./PatternBadge.astro";
import type { RecentPatternPreview } from "../lib/recent-pattern-previews";
import { i18n } from "../i18n";

const { item } = Astro.props as { item: RecentPatternPreview };
const { lang, t, href } = i18n(Astro);

// Intl.RelativeTimeFormat localiza "hace X" / "X ago" / "há X" sin diccionario.
function timeAgoLabel(iso: string): string {
    const rtf = new Intl.RelativeTimeFormat(lang, { numeric: "auto" });
    const diffMs = new Date(iso).getTime() - Date.now(); // negativo = pasado
    const minutes = Math.round(diffMs / 60000);
    if (Math.abs(minutes) < 60) return rtf.format(minutes, "minute");
    const hours = Math.round(minutes / 60);
    if (Math.abs(hours) < 24) return rtf.format(hours, "hour");
    return rtf.format(Math.round(hours / 24), "day");
}
---

<Card interactive class="flex flex-col gap-sm p-md">
    <PatternBadge status={item.status} />

    <h3 class="font-headline-sm text-headline-sm text-on-surface">
        {item.title}
    </h3>

    <p class="text-body-sm text-on-surface-variant">
        {item.summary}
    </p>

    <div
        class="mt-auto flex items-center justify-between border-t border-surface-variant pt-md"
    >
        <span class="font-label-caps text-label-caps text-outline"
            >{timeAgoLabel(item.createdAt)}</span
        >
        <a
            href={href(item.href)}
            class="font-label-caps text-label-caps font-bold text-primary"
            >{t('recentCard.readMore')}</a
        >
    </div>
</Card>
