---
// Resultado de verificación. Escucha eventos del formulario
// y se encarga de mostrar el veredicto, error o loading.
---

<!-- Estado de error (oculto por defecto) -->
<section
    id="verify-error"
    class="hidden border border-error bg-error-container/10 rounded-lg p-lg"
    role="alert"
>
    <div class="flex items-start gap-md">
        <span
            class="material-symbols-outlined text-error shrink-0"
            aria-hidden="true">error</span
        >
        <div class="flex flex-col gap-xs">
            <p
                class="font-label-caps text-label-caps text-error font-bold uppercase"
            >
                Error de verificación
            </p>
            <p
                id="verify-error-msg"
                class="font-body-md text-body-md text-on-surface"
            >
            </p>
        </div>
    </div>
</section>

<!-- Resultado (oculto hasta verificar) -->
<section
    id="verify-result"
    class="hidden flex-col border border-outline-variant bg-surface-container-lowest rounded-lg overflow-hidden"
>
    <!-- Banner de veredicto -->
    <div
        id="result-banner"
        class="border-t-[6px] p-lg flex justify-between items-center"
    >
        <div class="flex items-center gap-md">
            <span
                id="result-icon"
                class="material-symbols-outlined"
                style="font-size: 32px; font-variation-settings: 'FILL' 1;"
                aria-hidden="true"></span>
            <h2
                id="result-verdict"
                class="font-headline-md text-headline-md tracking-widest uppercase"
            >
            </h2>
        </div>
        <div
            class="bg-surface-container-high px-sm py-xs rounded flex items-center gap-xs"
        >
            <span class="font-label-caps text-[10px] text-on-surface-variant"
                >CONFIANZA:</span
            >
            <span
                id="result-confidence"
                class="font-label-caps text-label-caps text-primary"></span>
        </div>
    </div>

    <!-- Explicación -->
    <div class="p-lg border-t border-outline-variant">
        <p
            id="result-explanation"
            class="font-body-lg text-body-lg text-on-surface leading-[1.6] whitespace-pre-line"
        >
        </p>
    </div>

    <!-- Metadatos: patrones y fuentes -->
    <div
        class="p-lg bg-surface-container-low flex flex-col gap-lg border-t border-outline-variant"
    >
        <div id="result-patterns-wrap" class="hidden flex-col gap-sm">
            <h3
                class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider"
            >
                Patrones detectados
            </h3>
            <div id="result-patterns" class="flex flex-col gap-sm"></div>
        </div>

        <div class="flex flex-col gap-sm">
            <h3
                class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider"
            >
                Fuentes y evidencias
            </h3>
            <ul id="result-sources" class="flex flex-col gap-xs"></ul>
            <p
                id="result-sources-empty"
                class="hidden font-body-sm text-body-sm text-on-surface-variant"
            >
                No se encontraron fuentes para esta consulta.
            </p>
        </div>
    </div>
</section>

<script>
    const $ = (id: string) => document.getElementById(id);

    // ─── Estilos por veredicto ───────────────────────────
    const VERDICT_CONFIG = {
        verdadero: {
            banner: "border-secondary bg-secondary-container/10",
            text: "text-secondary",
            icon: "check_circle",
            label: "VERDADERO",
        },
        falso: {
            banner: "border-error bg-error-container/10",
            text: "text-error",
            icon: "cancel",
            label: "FALSO",
        },
        dudoso: {
            banner: "border-tertiary bg-tertiary-container/10",
            text: "text-tertiary",
            icon: "help",
            label: "DUDOSO",
        },
    } as const;

    type Verdict = keyof typeof VERDICT_CONFIG;

    function confidenceLabel(c: number): string {
        const pct = Math.round(c * 100);
        const tier = c >= 0.7 ? "ALTA" : c >= 0.4 ? "MEDIA" : "BAJA";
        return `${tier} · ${pct}%`;
    }

    // ─── Referencias DOM ────────────────────────────────
    const result = $("verify-result");
    const errorBox = $("verify-error");
    const errorMsg = $("verify-error-msg");

    // ─── Render ──────────────────────────────────────────
    function renderResult(res: {
        verdict: string;
        confidence: number;
        explanation: string;
        patterns: string[];
        sources: string[];
    }) {
        const cfg =
            VERDICT_CONFIG[res.verdict as Verdict] ?? VERDICT_CONFIG.dudoso;

        const banner = $("result-banner");
        if (banner)
            banner.className = `border-t-[6px] p-lg flex justify-between items-center ${cfg.banner}`;

        const icon = $("result-icon");
        if (icon) {
            icon.className = `material-symbols-outlined ${cfg.text}`;
            icon.textContent = cfg.icon;
        }

        const verdict = $("result-verdict");
        if (verdict) {
            verdict.className = `font-headline-md text-headline-md tracking-widest uppercase ${cfg.text}`;
            verdict.textContent = cfg.label;
        }

        const conf = $("result-confidence");
        if (conf) conf.textContent = confidenceLabel(res.confidence);

        const explanation = $("result-explanation");
        if (explanation) explanation.textContent = res.explanation;

        // Patrones
        const patternsWrap = $("result-patterns-wrap");
        const patterns = $("result-patterns");
        if (patterns && patternsWrap) {
            patterns.innerHTML = "";
            if (res.patterns.length > 0) {
                patternsWrap.classList.remove("hidden");
                patternsWrap.classList.add("flex");
                for (const p of res.patterns) {
                    const row = document.createElement("div");
                    row.className =
                        "bg-surface-container-lowest border border-outline-variant p-md flex items-center gap-md rounded";
                    row.innerHTML = `<span class="material-symbols-outlined ${cfg.text}" aria-hidden="true">hub</span><span class="font-label-caps text-label-caps text-on-surface"></span>`;
                    row.querySelector("span:last-child")!.textContent = p;
                    patterns.appendChild(row);
                }
            } else {
                patternsWrap.classList.add("hidden");
                patternsWrap.classList.remove("flex");
            }
        }

        // Fuentes
        const sources = $("result-sources") as HTMLUListElement | null;
        const sourcesEmpty = $("result-sources-empty");
        if (sources && sourcesEmpty) {
            sources.innerHTML = "";
            if (res.sources.length > 0) {
                sourcesEmpty.classList.add("hidden");
                for (const url of res.sources) {
                    let host = url;
                    try {
                        host = new URL(url).hostname.replace(/^www\./, "");
                    } catch {
                        /* keep original */
                    }
                    const li = document.createElement("li");
                    const a = document.createElement("a");
                    a.href = url;
                    a.target = "_blank";
                    a.rel = "noopener noreferrer";
                    a.className =
                        "font-body-sm text-body-sm text-secondary hover:underline break-all flex items-center gap-xs";
                    a.innerHTML = `<span class="material-symbols-outlined text-[16px]" aria-hidden="true">open_in_new</span>`;
                    a.append(host);
                    li.appendChild(a);
                    sources.appendChild(li);
                }
            } else {
                sourcesEmpty.classList.remove("hidden");
            }
        }

        result?.classList.remove("hidden");
        result?.classList.add("flex");
        result?.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    // ─── Eventos ─────────────────────────────────────────
    document.addEventListener("verify:reset", () => {
        result?.classList.add("hidden");
        errorBox?.classList.add("hidden");
    });

    document.addEventListener("verify:result", ((e: CustomEvent) => {
        errorBox?.classList.add("hidden");
        renderResult(e.detail);
    }) as EventListener);

    document.addEventListener("verify:error", ((e: CustomEvent) => {
        result?.classList.add("hidden");
        if (errorMsg) errorMsg.textContent = e.detail.message;
        errorBox?.classList.remove("hidden");
        errorBox?.scrollIntoView({ behavior: "smooth", block: "start" });
    }) as EventListener);
</script>
