---
import { i18n, type UIKey } from '../i18n'

interface NavItem {
  /** Clave estable del item (no cambia entre idiomas). */
  key: string
  labelKey: UIKey
  icon: string
  path: string
}

interface Props {
  /** Clave del item activo: 'inicio' | 'verificar' | 'patrones' | 'asistente'. */
  active?: string
}

const { active } = Astro.props
const { t, href } = i18n(Astro)

const items: NavItem[] = [
  { key: 'inicio', labelKey: 'nav.inicio', icon: 'home', path: '/' },
  { key: 'verificar', labelKey: 'nav.verificar', icon: 'fact_check', path: '/verificar' },
  { key: 'patrones', labelKey: 'nav.patrones', icon: 'query_stats', path: '/patrones' },
  { key: 'asistente', labelKey: 'nav.asistente', icon: 'chat', path: '/asistente' },
]
---

<nav
  class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 py-2 bg-surface border-t border-outline-variant"
  aria-label={t('nav.bottomNav')}
>
  {
    items.map((item) =>
      item.key === active ? (
        <a
          href={href(item.path)}
          aria-current="page"
          class="flex flex-col items-center justify-center bg-primary-container text-on-primary-container rounded-xl px-4 py-1"
        >
          <span class="material-symbols-outlined">{item.icon}</span>
          <span class="font-label-caps text-label-caps">{t(item.labelKey)}</span>
        </a>
      ) : (
        <a
          href={href(item.path)}
          class="flex flex-col items-center justify-center text-on-surface-variant"
        >
          <span class="material-symbols-outlined">{item.icon}</span>
          <span class="font-label-caps text-label-caps">{t(item.labelKey)}</span>
        </a>
      ),
    )
  }
</nav>
