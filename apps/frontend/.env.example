# Frontend (Astro) — copiá a .env y ajustá.
# Solo las variables con prefijo PUBLIC_ llegan al navegador.

# URL base del backend (Cloudflare Worker); el cliente le añade /rpc.
# Local: http://localhost:8787
PUBLIC_API_URL=http://localhost:8787

# false = usa el backend real vía oRPC.
# Cualquier otro valor (o ausente) = datos mock.
PUBLIC_MOCK_API=false
