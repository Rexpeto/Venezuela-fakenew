{
  "name": "frontend-verifica-venezuela",
  "compatibility_date": "2026-06-27",
  // The Cloudflare SSR runtime needs node: builtins (oRPC client, etc.).
  "compatibility_flags": ["nodejs_compat"],
  // KV namespace backing Astro server sessions (binding auto-added by the adapter).
  // Create it with: wrangler kv namespace create SESSION
  // then paste the returned id below.
  "kv_namespaces": [
    { "binding": "SESSION", "id": "<ID>" }
  ]
}
