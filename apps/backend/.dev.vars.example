TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token-here
# LLM: Anthropic key (sk-ant-…) auto-routes to the native provider; any other
# key uses the OpenAI-compatible endpoint. Set LLM_BASE_URL for HF/Groq.
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5-20251001
# LLM_BASE_URL=https://api.groq.com/openai/v1
TAVILY_API_KEY=tvly-...
# Exact frontend origin in prod; defaults to * (fail-open) if unset.
CORS_ORIGIN=http://localhost:4321
